{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Iniciar servidor",
			"skipFiles": ["<node_internals>/**"],
			"program": "${workspaceFolder}/src/index.js",
			"envFile": "${workspaceFolder}/.env"
		},
		{
			"type": "node",
			"request": "attach",
			"name": "Adjuntar a nodemon",
			"port": 9229,
			"restart": true,
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
